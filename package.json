{
	"name": "@heiwa4126/clean-publish-scripts",
	"version": "0.0.6-rc.1",
	"description": "A simple CLI tool to clean package.json during npm publish by removing development-specific fields like scripts, workspaces, and private.",
	"keywords": [
		"build-tools",
		"clean",
		"cli",
		"npm",
		"package.json",
		"postpack",
		"prepack",
		"publish",
		"typescript"
	],
	"license": "MIT",
	"author": "heiwa4126 <heiwa4126@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/heiwa4126/clean-publish-scripts.git"
	},
	"bin": {
		"clean-publish-scripts": "dist/cli.js"
	},
	"files": [
		"dist/**/*.js",
		"dist/**/*.cjs",
		"dist/**/*.d.ts",
		"!dist/**/*.map"
	],
	"type": "module",
	"main": "./dist/lib.cjs",
	"module": "./dist/lib.js",
	"types": "./dist/lib.d.ts",
	"exports": {
		".": {
			"types": "./dist/lib.d.ts",
			"import": "./dist/lib.js",
			"require": "./dist/lib.cjs"
		}
	},
	"scripts": {
		"preinstall": "pnpm audit",
		"build": "tsdown",
		"cli": "node dist/cli.js",
		"test": "tsx --test tests/**/*.test.ts",
		"test:run": "tsx --test tests/**/*.test.ts",
		"test:watch": "tsx --watch --test tests/**/*.test.ts",
		"test:coverage": "node --import tsx --test --experimental-test-coverage tests/**/*.test.ts",
		"prepublishOnly": "run-s lint test build smoke-test",
		"format": "oxfmt",
		"lint": "oxlint",
		"check": "oxfmt && oxlint --fix",
		"format:pkg": "pnpm pkg fix --loglevel=error",
		"format:all": "run-s format:pkg check",
		"smoke-test:ems": "node smoke-test/st.mjs",
		"smoke-test:cjs": "node smoke-test/st.cjs",
		"smoke-test:ts": "node smoke-test/st.ts",
		"smoke-test": "run-p smoke-test:* cli",
		"prepack": "node dist/cli.js -c",
		"postpack": "node dist/cli.js -r",
		"ver": "pnpm pkg get version --loglevel=error",
		"trivy": "trivy config . && trivy fs --exit-code 1 --severity HIGH,CRITICAL .",
		"sbom": "trivy fs --scanners vuln --format spdx-json --output sbom.spdx.json .",
		"osv-scan": "osv-scanner scan -L pnpm-lock.yaml",
		"cloc": "cloc $(git ls-files|grep -Fv pnpm-lock.yaml)",
		"lizard": "lizard -EDuplicate -w .",
		"lizard:all": "lizard -EDuplicate .",
		"g": "run-s osv-scan format:all prepublishOnly"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"npm-run-all2": "^8.0.4",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"tsdown": "0.21.10",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
